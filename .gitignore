# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ───── 依存関係 ─────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ───── テスト・ビルド ─────
/coverage
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ───── ログ・デバッグ ─────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ───── OS・エディタ ─────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ───── 秘密情報（絶対コミットしない）─────
# .env系（ローカル環境変数）
.env
.env.*

# Cloud Run用（SP-API / DB認証情報などが入る）
env-cloudrun.yaml
env-*.yaml

# GCPサービスアカウント鍵
*-key.json
service-account*.json
credentials.json

# SSH鍵・SSL証明書
*.pem
*.key
*.secret
id_rsa*
id_ed25519*

# ───── Claude Code ローカル設定 ─────
.claude/settings.local.json
.claude/worktrees/

# ───── Vercel ─────
.vercel
